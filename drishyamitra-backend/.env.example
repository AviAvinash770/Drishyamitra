# Drishyamitra Backend Environment Variables
# Copy this file as .env and fill in your own values:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)

SECRET_KEY=drishyamitra-super-secret-key-change-in-production
DATABASE_URL=sqlite:///drishyamitra.db
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800
CHROMA_PERSIST_DIR=./chroma_data

# Groq API Key (required for AI Assistant)
# Get yours free at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key (required for AI Vision Auto-Tagging)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google OAuth 2.0 (required for Google Login verification)
# Get yours at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here

# Email sharing & Data Backups (SMTP Setup)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_app_password
MAIL_USE_TLS=True
MAIL_DEFAULT_SENDER=no-reply@drishyamitra.com

# WhatsApp sharing (Twilio API) — Optional
# Sign up free at: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional: Public tunnel URL for WhatsApp image attachments
PUBLIC_BASE_URL=

# Cloudinary Integration (For production-ready object storage)
# You can define either CLOUDINARY_URL or individual cloud credentials:
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
